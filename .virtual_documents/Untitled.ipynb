import pandas as pd 
import requests


response=requests.get('https://api.themoviedb.org/3/movie/top_rated?api_key=5cfc0bb3ade614aa86578674158c1c46&language=en-US&page=1') 


pd.DataFrame(response.json()['results']).head(2)


